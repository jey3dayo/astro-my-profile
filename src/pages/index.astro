---
import Content from "@/contents/profile.md";
import Layout from "@/layouts/Layout.astro";

const appName = import.meta.env.APP_NAME ?? "";
const siteDomain = import.meta.env.SITE_DOMAIN ?? "";
---

<Layout title={appName}>
  <main class="hero relative min-h-screen bg-white pb-20">
    <div class="absolute top-0 left-0 p-3 text-2xl font-bold text-white sm:p-4 sm:text-4xl md:text-6xl">
      {siteDomain}
    </div>
    <div class="absolute inset-x-0 bottom-10 mx-2 rounded-sm bg-black/50 p-3 text-white sm:left-auto sm:mx-4 sm:p-4">
      <h2 class="text-xl font-semibold sm:text-2xl md:text-3xl">Who am I ?</h2>
      <p class="mt-2 overflow-x-auto text-sm sm:text-base"><Content /></p>
    </div>
    <footer
      class="text-light absolute bottom-0 left-0 w-full bg-black/50 px-2 py-1 text-center text-xs sm:text-sm md:text-base"
    >
      ©{new Date().getFullYear()}
      {siteDomain}
    </footer>
  </main>
</Layout>
