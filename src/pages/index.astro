---
import Content from "@/contents/profile.md";
import Layout from "@/layouts/Layout.astro";
import { APP_NAME, SITE_DOMAIN } from "astro:env/client";

const appName = APP_NAME ?? "";
const siteDomain = SITE_DOMAIN ?? "";
---

<Layout title={appName}>
  <main class="hero relative flex min-h-[100svh] min-h-screen flex-col bg-white lg:block lg:pb-20">
    <div class="p-3 text-2xl font-bold text-white lg:absolute lg:top-0 lg:left-0 lg:p-4 lg:text-4xl xl:text-6xl">
      {siteDomain}
    </div>
    <div
      class="mx-2 mt-2 rounded-sm bg-black/50 p-3 text-white lg:absolute lg:inset-x-0 lg:bottom-10 lg:left-auto lg:mx-4 lg:mt-0 lg:p-4"
    >
      <h2 class="text-xl font-semibold lg:text-2xl xl:text-3xl">Who am I ?</h2>
      <p class="mt-2 overflow-x-auto text-sm lg:text-base"><Content /></p>
    </div>
    <footer
      class="text-light mt-auto w-full bg-black/50 px-2 py-1 text-center text-xs lg:absolute lg:bottom-0 lg:left-0 lg:text-sm xl:text-base"
    >
      ©{new Date().getFullYear()}
      {siteDomain}
    </footer>
  </main>
</Layout>
