    "@typescript-eslint/parser": "latest",
    "env-cmd": "^11.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-turbo": "^2.8.12",
    "eslint-plugin-astro": "^1.6",
    "eslint-plugin-react": "^7.37",
    "eslint-plugin-tailwindcss": "^3.18",
    "husky": "^9.1",
    "lint-staged": "^16",
    "npm-run-all": "^4.1.5",
    "prettier": "3.8",
