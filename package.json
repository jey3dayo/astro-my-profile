{
  "name": "astro-my-profile",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "bun@1.3.10",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "husky:install": "husky install .husky",
    "dev": "dotenvx run -- astro dev",
    "start": "dotenvx run -- astro dev",
    "build": "run-p test astro:build",
    "preview": "dotenvx run -- astro preview",
    "astro": "astro",
    "astro:build": "dotenvx run -- astro build",
    "deploy": "run-s astro:build cf:deploy",
    "cf:deploy": "dotenvx run -- wrangler deploy",
    "cf:preview": "dotenvx run -- wrangler dev",
    "cf:logs": "dotenvx run -- wrangler tail --format pretty",
    "env:encrypt": "dotenvx encrypt",
    "env:decrypt": "dotenvx decrypt",
    "test": "run-p test:*",
    "test:eslint": "eslint .",
    "test:prettier": "prettier --check --cache './**/*.{js,mjs,cjs,jsx,ts,tsx,astro,json,css,yml,yaml}'",
    "test:astro": "astro check",
    "format": "run-s format:*",
    "format:write": "prettier --write --cache './**/*.{js,mjs,cjs,jsx,ts,tsx,astro,json,css,yml,yaml}'",
    "format:eslint": "eslint --fix .",
    "ncu": "ncu -u"
  },
  "devDependencies": {
    "@commitlint/cli": "^20",
    "@commitlint/config-conventional": "^20",
    "@dotenvx/dotenvx": "^1.52.0",
    "@eslint/js": "^10.0.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.7",
    "@tailwindcss/vite": "^4.2.1",
    "ansi-align": "3",
    "astro-eslint-parser": "^1.3.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-turbo": "^2.8.12",
    "eslint-plugin-astro": "^1.6",
    "husky": "^9.1",
    "lint-staged": "^16",
    "npm-run-all": "^4.1.5",
    "prettier": "3.8",
    "prettier-plugin-astro": "^0.14",
    "prettier-plugin-tailwindcss": "^0.7",
    "string-width": "8",
    "wrangler": "^4.69.0"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/cloudflare": "^12.6.12",
    "@astrojs/react": "^4.4.2",
    "@icons-pack/react-simple-icons": "^13.11.2",
    "@radix-ui/colors": "^3.0.0",
    "@types/node": "^22",
    "@types/react": "^19.2",
    "@types/react-dom": "^19.2",
    "astro": "^5.18.0",
    "clsx": "^2.1.1",
    "eslint-config-flat-gitignore": "^2.2.1",
    "react": "^19.2",
    "react-dom": "^19.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1",
    "typescript": "^5.9",
    "typescript-eslint": "^8.56.1"
  }
}
